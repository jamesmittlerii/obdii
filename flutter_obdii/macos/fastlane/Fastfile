# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:mac)

platform :mac do
  before_all do
    setup_ci if ENV['CI']
    ENV["DELIVER_ALTOOL_ADDITIONAL_UPLOAD_PARAMETERS"] = "--use-old-altool"
    # macOS often requires 'appstore' type for TestFlight
    match(type: "appstore", platform: "macos", additional_cert_types: ["mac_installer_distribution"])
  end

  desc "Push a new macOS build to TestFlight"
  lane :beta do
    project_name = ENV['PROJECT_NAME'].to_s.strip
    
    # Logic for targets remains similar
    flutter_target = project_name == 'obdiic' ? 'lib/main_cupertino.dart' : 'lib/main_material.dart'
    bundle_id = ENV['APP_IDENTIFIER'].to_s.strip
    bundle_id = "com.rheosoft.#{project_name}" if bundle_id.empty?

    # Provisioning for macOS
    provisioning_profile = ENV['PROVISIONING_PROFILE_SPECIFIER_MACOS'].to_s.strip
    provisioning_profile = "match AppStore #{bundle_id} macos" if provisioning_profile.empty?

    # macOS project paths (relative to the macos folder)
    macos_project_file = "Runner.xcodeproj"
    info_plist_path = "Runner/Info.plist"

    update_code_signing_settings(
      use_automatic_signing: false,
      path: macos_project_file,
      team_id: "L97LVVC8Y4",
      bundle_identifier: bundle_id,
      profile_name: provisioning_profile,
      targets: ["Runner"],
      build_configurations: ["Release"]
    )

    # Build the macOS app via Flutter
    sh "cd .. && flutter build macos --release -t #{flutter_target}"

    sh("security find-identity -v -p codesigning")

    # Build and Archive for macOS
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      sdk: "macosx", 
      destination: "generic/platform=macOS",
      export_method: "app-store", # Changed from 'app-store' to fix deprecation
      export_options: {
        signingStyle: "manual",
        # This is the missing link:
        installerSigningCertificate: "3rd Party Mac Developer Installer: James Mittler II (L97LVVC8Y4)",
        provisioningProfiles: {
          bundle_id => provisioning_profile,
        },
      },
      xcargs: "CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY='Apple Distribution' DEVELOPMENT_TEAM=L97LVVC8Y4"
    )


    app_store_connect_api_key
    upload_to_testflight(
      # 'platform' is inferred from the build_app output, but you can be explicit
      skip_waiting_for_build_processing: false
    )
  end
end
